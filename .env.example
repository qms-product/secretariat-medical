# ============================================
# Secretariat Medical - Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or .env with real keys.
# All keys are server-side only (ADR-1).

# Application port (ADR-10)
# Default: 3001 (to avoid conflicts with Cal.com on port 3000)
PORT=3001

# ElevenLabs API key (server-side only)
# Used for Speech-to-Text (STT) and Text-to-Speech (TTS)
# Obtain from: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Anthropic API key (server-side only)
# Used for Claude conversational processing
# Obtain from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ============================================
# Cal.com Integration (ADR-8)
# ============================================

# Cal.com API key (server-side only)
# Used for booking appointments via Cal.com
# Obtain from: https://app.cal.com/settings/developer/api-keys
CAL_COM_API_KEY=

# Cal.com base URL
# Default: http://localhost:3000 for local Cal.com instance
CAL_COM_BASE_URL=http://localhost:3000

# Cal.com event type ID
# The ID of the event type used for appointment bookings
CAL_COM_EVENT_TYPE_ID=
